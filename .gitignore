# Dépendances PHP
/vendor/

# Données locales (base, clés API, sessions, fichiers volumineux)
/data/moncine.db
/data/moncine.db-journal
/data/moncine.db-wal
/data/moncine.db-shm
/data/omdb_api_key.txt
/data/tmdb_api_key.txt
/data/sessions/*
!/data/sessions/.gitkeep
/data/auth_rate_limit/
/data/media/

# Graine d’installation : déposer CSV/ZIP ici sans les versionner
/install_seed/*.zip
/install_seed/*.ods
/install_seed/abm-*.json

# Cache ponctuel script ABM (lib/cli/abm-fetch-catalog.php)
/data/abm-fetch-cache/

# Affiches téléchargées
/data/posters/
/www/posters/*
!/www/posters/.gitkeep

# Outils / IDE
/.idea/
/.vscode/
*.swp
*~
.DS_Store

# Tests / cache
/.phpunit.cache/
/phpunit.xml

# Captures doc (fichiers lourds, optionnels en local)
/doc/Screenshots/*
!/doc/Screenshots/README.md

# Logs
*.log
